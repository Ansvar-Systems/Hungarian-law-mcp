{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Hungarian Law MCP",
  "description": "Golden contract tests for the Hungarian Law MCP -- 12 tests covering article retrieval, search, citation, cross-reference, and negative cases",
  "tests": [
    {
      "id": "hu-001",
      "category": "article_retrieval",
      "description": "Retrieve Infotörvény § 1 (Act CXII of 2011) -- purpose and scope of data protection law implementing GDPR",
      "tool": "get_provision",
      "input": {
        "document_id": "act-cxii-2011-info-self-determination",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["informational self-determination", "personal data", "Regulation (EU) 2016/679", "GDPR"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "hu-002",
      "category": "article_retrieval",
      "description": "Retrieve Ibtv. § 11 (Act L of 2013) -- incident reporting obligations for cybersecurity",
      "tool": "get_provision",
      "input": {
        "document_id": "act-l-2013-electronic-info-security",
        "section": "11"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["incident", "24 hours", "competent authority", "NIS2"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "hu-003",
      "category": "article_retrieval",
      "description": "Retrieve Criminal Code § 422 -- unauthorised access to information systems",
      "tool": "get_provision",
      "input": {
        "document_id": "criminal-code-cybercrime",
        "section": "422"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["unauthorised access", "information system", "imprisonment", "Directive 2013/40/EU"],
        "fields_present": ["content", "provision_ref"],
        "text_not_empty": true
      }
    },
    {
      "id": "hu-004",
      "category": "article_retrieval",
      "description": "Retrieve Trade Secrets Act § 2 (Act LIV of 2018) -- definition of trade secret",
      "tool": "get_provision",
      "input": {
        "document_id": "act-liv-2018-trade-secrets",
        "section": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["trade secret", "commercial value", "secret", "Directive (EU) 2016/943"],
        "fields_present": ["content"],
        "text_not_empty": true
      }
    },
    {
      "id": "hu-005",
      "category": "search",
      "description": "Full-text search for 'personal data' returns Infotörvény and related provisions",
      "tool": "search_legislation",
      "input": {
        "query": "personal data"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["personal data", "data subject", "data protection", "GDPR"]
      }
    },
    {
      "id": "hu-006",
      "category": "search",
      "description": "Full-text search for 'cybersecurity' returns Ibtv. and related provisions",
      "tool": "search_legislation",
      "input": {
        "query": "cybersecurity"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["cybersecurity", "security", "information system", "incident"]
      }
    },
    {
      "id": "hu-007",
      "category": "search",
      "description": "Full-text search for 'critical infrastructure' returns Lrtv. provisions",
      "tool": "search_legislation",
      "input": {
        "query": "critical infrastructure"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["critical infrastructure", "essential", "resilience", "operator"]
      }
    },
    {
      "id": "hu-008",
      "category": "citation_roundtrip",
      "description": "Citation for Infotörvény includes njt.hu URL pattern",
      "tool": "get_provision",
      "input": {
        "document_id": "act-cxii-2011-info-self-determination",
        "section": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "njt\\.hu",
        "text_not_empty": true
      }
    },
    {
      "id": "hu-009",
      "category": "citation_roundtrip",
      "description": "Citation for Criminal Code cybercrime provisions includes njt.hu URL pattern",
      "tool": "get_provision",
      "input": {
        "document_id": "criminal-code-cybercrime",
        "section": "375"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "njt\\.hu",
        "text_not_empty": true
      }
    },
    {
      "id": "hu-010",
      "category": "eu_cross_reference",
      "description": "Infotörvény cross-reference to GDPR -- Hungarian data protection law implements Regulation (EU) 2016/679",
      "tool": "get_eu_basis",
      "input": {
        "document_id": "act-cxii-2011-info-self-determination"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["2016/679", "GDPR", "regulation", "Regulation"]
      }
    },
    {
      "id": "hu-011",
      "category": "negative_test",
      "description": "Non-existent Hungarian law returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "2099-evi-MMMM-torveny-a-fikcio",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "hu-012",
      "category": "negative_test",
      "description": "Malformed section number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "act-cxii-2011-info-self-determination",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
