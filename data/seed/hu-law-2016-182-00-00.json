    },
    {
      "provision_ref": "s33",
      "chapter": "I. Fejezet",
      "section": "33",
      "title": "33. §",
      "content": "33. § Az egyes adótörvények és más kapcsolódó törvények, valamint a Nemzeti Adó- és Vámhivatalról szóló 2010. évi CXXII. törvény módosításáról szóló 2016. évi LXVI. törvény 33. §-ának a Katv. 23. § (2) bekezdését megállapító rendelkezése a „16” szövegrész helyett a „14” szöveggel lép hatályba."
    },
    {
      "provision_ref": "s34",
      "chapter": "I. Fejezet",
      "section": "34",
      "title": "34. §",
      "content": "34. § Nem lép hatályba az egyes adótörvények és más kapcsolódó törvények módosításáról szóló 2016. évi CXXV. törvény 1. 16. § (2) bekezdése, 2. 22. §-a, 3. 53. §-a."
    },
